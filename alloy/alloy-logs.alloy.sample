// Adjust alloy-logs.alloy, but not .sample, if you want to adjust log level or trace target
logging {
  level  = "info"
  format = "logfmt"
}

tracing {
  sampling_fraction = 0.1

  write_to = [otelcol.exporter.otlp.tempo.input]
}

otelcol.exporter.otlp "tempo" {
  client {
    endpoint = "tempo:4317"
    tls {
      insecure = true
    }
  }
}
